# OS junk
Thumbs.db
.DS_Store

# Local Claude Code state
.claude/settings.local.json

# Personalization marker — proves the current user claimed this copy.
# Must never ship, so a fresh clone keeps the first-run guard armed.
.feed-personalized

# Personal state — never shipped. Templates ship as *.example.* instead.
# Your real files live only on your disk; a fresh clone bootstraps them
# from the templates via `/feed setup`.
watchlist.csv
seen_posts.csv
profile/interests.md
digest/*.md
!digest/.gitkeep
